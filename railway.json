{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "backend": {
      "source": "backend/",
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "Dockerfile"
      },
      "deploy": {
        "numReplicas": 1,
        "sleep": false
      }
    },
    "frontend": {
      "source": "frontend/",
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "Dockerfile"
      },
      "deploy": {
        "numReplicas": 1,
        "sleep": false
      }
    }
  }
}
