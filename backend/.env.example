# ── Server ─────────────────────────────────────────────
PORT=8080
GIN_MODE=release

# ── Google OAuth ───────────────────────────────────────
# 1. Go to: https://console.cloud.google.com
# 2. APIs & Services → Credentials → Create OAuth 2.0 Client ID
# 3. Application type: Web application
# 4. Authorised redirect URIs — add BOTH:
#    http://localhost:8080/auth/google/callback        (for local dev)
#    https://your-app.onrender.com/auth/google/callback (for production)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:8080/auth/google/callback

# ── Razorpay ───────────────────────────────────────────
# 1. Go to: https://dashboard.razorpay.com
# 2. Settings → API Keys → Generate Test Key
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# ── Frontend URL (CORS) ────────────────────────────────
# Local dev:   http://localhost:5173
# Production:  https://startupinspirator.github.io
CLIENT_URL=http://localhost:5173

# ── Database ───────────────────────────────────────────
DB_PATH=./aloe_raw.db

# ── Session ────────────────────────────────────────────
SESSION_SECRET=replace_with_any_random_32_character_string
